@model IEnumerable<Health_Booking_MVC.Models.Patient>
@{
    Layout = "~/Views/Admin/_Admin.cshtml";
    ViewData["Title"] = "Danh sách Bệnh nhân";
}

<div class="container-fluid">
    <div class="card card-custom bg-white p-4">
        <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-user-injured me-2 text-success"></i> Quản lý hồ sơ Bệnh nhân</h5>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã BN</th>
                        <th>Họ và Tên</th>
                        <th>Ngày sinh</th>
                        <th>Giới tính</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pat in Model)
                    {
                        <tr>
                            <td><strong>#@pat.PatientId</strong></td>
                            <td class="fw-semibold">@pat.FullName</td>
                            <td>@pat.DateOfBirth.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-light text-dark border">@pat.Gender</span></td>
                            <td>@pat.Phone</td>
                            <td><small class="text-muted">@pat.Address</small></td>
                            <td class="text-center">
                                <form asp-controller="Admin" asp-action="LockPatient" asp-route-id="@pat.PatientId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn khóa tài khoản bệnh nhân này không?');" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-light border text-danger me-1">
                                        <i class="fa-solid fa-user-lock"></i> Khóa
                                    </button>
                                </form>

                                <form asp-controller="Admin" asp-action="DeletePatient" asp-route-id="@pat.PatientId" method="post" onsubmit="return confirm('CẢNH BÁO: Xóa bệnh nhân sẽ xóa toàn bộ tài khoản liên quan! Bạn có chắc chắn muốn xóa không?');" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-trash"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>