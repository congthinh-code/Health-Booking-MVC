@using Health_Booking_MVC.Models
@model IEnumerable<Health_Booking_MVC.Models.Appointment>
@{
    Layout = "~/Views/Admin/_Admin.cshtml";
    ViewData["Title"] = "Quản lý Lịch hẹn từ Trang chủ";
}

<div class="container-fluid">
    <div class="card card-custom bg-white p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold m-0 text-dark">
                <i class="fa-solid fa-house-medical me-2 text-info"></i> Danh sách Lịch hẹn khám (Nguồn: Trang chủ)
            </h5>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã LH</th>
                        <th>Bệnh nhân</th>
                        <th>Chuyên khoa / Bệnh viện</th>
                        <th>Ngày hẹn</th>
                        <th>Giờ khám</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td><strong>#@app.AppointmentId</strong></td>
                                <td class="fw-semibold">@app.Patient?.FullName</td>
                                <td>
                                    <div class="small fw-bold text-dark">@app.Specialization?.Name</div>
                                    <div class="small text-muted">@app.Hospital?.Name</div>
                                </td>
                                <td>@app.AppointmentDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="fa-regular fa-clock me-1 text-success"></i>
                                        @* 🔥 ĐÃ SỬA: Đổi từ item.AppointmentDate thành app.AppointmentDate *@
                                        @app.AppointmentDate.ToString("HH:mm")
                                    </span>
                                </td>
                                <td>
                                    @if (app.Status == AppointmentStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock me-1"></i> Chờ duyệt</span>
                                    }
                                    else if (app.Status == AppointmentStatus.Confirmed)
                                    {
                                        <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i> Đã xác nhận</span>
                                    }
                                    else if (app.Status == AppointmentStatus.Completed)
                                    {
                                        <span class="badge bg-info text-dark"><i class="fa-solid fa-square-check me-1"></i> Hoàn thành</span>
                                    }
                                    else if (app.Status == AppointmentStatus.Cancelled)
                                    {
                                        <span class="badge bg-danger"><i class="fa-solid fa-xmark me-1"></i> Đã hủy</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (app.Status == AppointmentStatus.Pending)
                                    {
                                        <form asp-controller="Admin" asp-action="ConfirmAppointment" asp-route-id="@app.AppointmentId" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xác nhận lịch hẹn khám này không?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success me-1">
                                                <i class="fa-solid fa-circle-check"></i> Xác nhận
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-light border me-1" disabled>
                                            <i class="fa-solid fa-ban"></i> Đã xử lý
                                        </button>
                                    }

                                    <form asp-controller="Admin" asp-action="DeleteAppointment" asp-route-id="@app.AppointmentId" method="post" style="display:inline;" onsubmit="return confirm('⚠️ CẢNH BÁO: Bạn có chắc chắn muốn XÓA VĨNH VIỄN lịch hẹn này không? Thao tác này không thể hoàn tác!');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fa-solid fa-trash-can"></i> Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Hiện tại không có lịch hẹn nào được đặt từ Trang chủ.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>