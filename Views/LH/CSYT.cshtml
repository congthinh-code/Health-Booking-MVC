                    <p class="hospital-address">
                        <i class="fa-solid fa-location-dot"></i>
                        <?= htmlspecialchars($hospital['address']) ?>
                    </p>
                    <div class="hospital-rating">
                        <div class="stars">
                            <?php for ($i = 0; $i < $hospital['rating']; $i++): ?>
                            <i class="fa-solid fa-star"></i>
                            <?php endfor; ?>
                        </div>
                        <span class="rating-value"><?= htmlspecialchars($hospital['rating']) ?>/5</span>
                    </div>
                </div>
            </div>
            <?php endforeach; ?>
            <?php else: ?>
            <div class="no-hospitals">
                <p>Không có cơ sở y tế nào</p>
            </div>
            <?php endif; ?>
        </div>

        <!-- PAGINATION -->
        <div class="pagination">
            <?php if ($page > 1): ?>
            <a href="?page=1" class="pagination-btn first-btn">
                <i class="fa-solid fa-angles-left"></i>
            </a>
            <a href="?page=<?= $page - 1 ?>" class="pagination-btn">
                <i class="fa-solid fa-angle-left"></i>
            </a>
            <?php endif; ?>

            <div class="pagination-numbers">
                <?php
                $start_page = max(1, $page - 2);
                $end_page = min($totalPages, $page + 2);

                if ($start_page > 1): ?>
                <a href="?page=1" class="pagination-btn">1</a>
                <?php if ($start_page > 2): ?>
                <span class="pagination-ellipsis">...</span>
                <?php endif; ?>
                <?php endif; ?>

                <?php for ($i = $start_page; $i <= $end_page; $i++): ?>
                <a href="?page=<?= $i ?>" class="pagination-btn <?= ($i == $page) ? 'active' : '' ?>"><?= $i ?></a>
                <?php endfor; ?>

                <?php if ($end_page < $totalPages): ?>
                <?php if ($end_page < $totalPages - 1): ?>
                <span class="pagination-ellipsis">...</span>
                <?php endif; ?>
                <a href="?page=<?= $totalPages ?>" class="pagination-btn"><?= $totalPages ?></a>
                <?php endif; ?>
            </div>

            <?php if ($page < $totalPages): ?>
            <a href="?page=<?= $page + 1 ?>" class="pagination-btn">
                <i class="fa-solid fa-angle-right"></i>
            </a>
            <a href="?page=<?= $totalPages ?>" class="pagination-btn last-btn">
                <i class="fa-solid fa-angles-right"></i>
            </a>
            <?php endif; ?>
        </div>
    </div>
</section> *@

