@model List<Hospital>
@using Health_Booking_MVC.Models

<link rel="stylesheet" href="~/css/LH/QC.css" />
@{
    ViewData["Title"] = "Hợp tác quảng cáo cùng HealthMeet";
}

<!-- MENU TAB -->
<div class="tab-container">
    <a asp-controller="LH"
       asp-action="CSYT"
       class="tab-item">
        Cơ sở y tế
    </a>

    <a asp-controller="LH"
       asp-action="QC"
       class="tab-item active">
        Quảng cáo
    </a>

    <a asp-controller="LH"
       asp-action="TD"
       class="tab-item">
        Tuyển dụng
    </a>
</div>

<section class="banner-section">
    <div class="banner-content">
        <h1>Quảng cáo với HealthMeet</h1>
        <p>Nền tảng công nghệ kết nối khách hàng với các cơ sở y tế hàng đầu tại Việt Nam</p>
    </div>
</section>

<div class="container">
    <!-- Intro Section -->
    <section class="intro-section">
        <div class="intro-content">
            <h2>Về HealthMeet</h2>
            <p>HealthMeet là nền tảng công nghệ kết nối người dân với Cơ sở - Dịch vụ Y tế hàng đầu tại Việt Nam, mang lại giải pháp tiếp cận khách hàng tiềm năng và phù hợp nhu cầu thực tế. Chúng tôi cung cấp các gói quảng cáo linh hoạt để giúp bệnh viện, phòng khám, bác sĩ và các dịch vụ y tế khác tăng cường hiện diện trực tuyến và thu hút bệnh nhân.</p>
        </div>
    </section>

    <section class="partners-section">
        <h2>Hệ thống Cơ sở Y tế triển khai</h2>

        <div class="partners-grid">
            @foreach (var hospital in Model)
            {
                <div class="partner-item">
                    <div class="partner-img"
                         style="background-image:url('/@hospital.Image')">
                    </div>

                    <h3>@hospital.Name</h3>

                    <p>@hospital.Address</p>

                    <div class="rating">
                        <i class="fas fa-star"></i>
                        @hospital.Rating
                    </div>
                </div>
            }
        </div>
    </section>
</div>
<!-- Contact & Registration -->
<section class="contact-section">
    <h2>Liên hệ & Đăng ký quảng cáo</h2>
    <div class="contact-wrapper">

        <!-- Contact Info -->
        <div class="contact-info">
            <div class="info-item">
                <div class="info-icon">
                    <i class="fas fa-phone-alt"></i>
                </div>
                <div class="info-content">
                    <h3>Liên hệ tư vấn</h3>
                    <a href="tel:0000000000">0000 000 000</a>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <div class="info-content">
                    <h3>Địa chỉ</h3>
                    <p>Thành phố Quy Nhơn, Bình Định</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">
                    <i class="fas fa-envelope"></i>
                </div>
                <div class="info-content">
                    <h3>Email</h3>
                    <a href="mailto:quangcao@healthmeet.com">quangcao@healthmeet.com</a>
                </div>
            </div>
        </div>

        <!-- Registration Form -->
        <div class="registration-form">
            <h3>Đăng ký quảng cáo</h3>
            <form>
                <div class="form-group">
                    <label for="name">Họ và tên<span class="required">*</span></label>
                    <input type="text" id="name" name="name" required>
                </div>

                <div class="form-group">
                    <label for="company">Công ty<span class="required">*</span></label>
                    <input type="text" id="company" name="company" required>
                </div>

                <div class="form-group">
                    <label for="phone">Số điện thoại<span class="required">*</span></label>
                    <input type="tel" id="phone" name="phone" required>
                </div>

                <div class="form-group">
                    <label for="field">Lĩnh vực kinh doanh<span class="required">*</span></label>
                    <select id="field" name="field" required>
                        <option value="">-- Chọn lĩnh vực --</option>
                        <option value="benh-vien">Bệnh viện</option>
                        <option value="phong-kham">Phòng khám</option>
                        <option value="nha-thuoc">Nhà thuốc</option>
                        <option value="dung-cu-y-te">Dụng cụ y tế</option>
                        <option value="dich-vu-y-te-khac">Dịch vụ y tế khác</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="message">Nội dung yêu cầu</label>
                    <textarea id="message" name="message" rows="4" placeholder="Mô tả chi tiết về nhu cầu quảng cáo của bạn..."></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Đăng ký ngay</button>
            </form>
        </div>
    </div>
</section>
<script>
    // Form submission
    document.querySelector('.registration-form form').addEventListener('submit', function(e) {
      e.preventDefault();

      const formData = {
        name: document.getElementById('name').value,
        company: document.getElementById('company').value,
        phone: document.getElementById('phone').value,
        field: document.getElementById('field').value,
        message: document.getElementById('message').value
      };

      // Validate phone
      if (!/^[0-9]{10,11}$/.test(formData.phone)) {
        alert('Vui lòng nhập số điện thoại hợp lệ (10-11 chữ số)');
        return;
      }

      // Display confirmation
      alert('Cảm ơn bạn đã đăng ký! Chúng tôi sẽ liên hệ với bạn trong thời gian sớm nhất.');
      this.reset();
    });

    // Package button handlers
    document.querySelectorAll('.package-card .btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const packageName = this.closest('.package-card').querySelector('h3').textContent;
        document.getElementById('message').value = `Tôi muốn đăng ký gói: ${packageName}`;
        document.querySelector('.registration-form').scrollIntoView({ behavior: 'smooth' });
      });
    });
</script>