@model IEnumerable<Health_Booking_MVC.Models.Hospital>

@{
    ViewData["Title"] = "Bệnh viện công lập";
}

<div class="tab-container">
    <a asp-controller="CSYT" asp-action="BVCong" class="tab-item active">
        Bệnh viện công lập
    </a>
    <a asp-controller="CSYT" asp-action="BVTu" class="tab-item">
        Bệnh viện tư nhân
    </a>
</div>

<link rel="stylesheet" href="~/css/CSYT/BVCong.css" asp-append-version="true" />

<h2 class="title">Bệnh viện công lập</h2>
<h3 class="subtitle">Danh sách các bệnh viện công lập tại Bình Định</h3>

<div class="container">
    @foreach (var bv in Model)
    {
        <div class="card">
            <img src="/@bv.Image" alt="@bv.Name" />

            <h3 class="name">@bv.Name</h3>

            <p class="address">@bv.Address</p>

            <div class="stars">
                @for (int i = 0; i < bv.Rating; i++)
                {
                    <span>⭐</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(bv.WebsiteUrl))
            {
                <a class="btn" href="@bv.WebsiteUrl" target="_blank" rel="noopener noreferrer">
                    Xem chi tiết
                </a>
            }
            else
            {
                <a class="btn" href="#">
                    Xem chi tiết
                </a>
            }
        </div>
    }
</div>