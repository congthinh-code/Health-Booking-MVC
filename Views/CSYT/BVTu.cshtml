@{
    ViewData["Title"] = "Bệnh viện tư nhân";

    var benhViens = new[]
    {
        new
        {
            Ten = "Bệnh viện Bình Định",
            DiaChi = "39A Phạm Ngọc Thạch, TP Quy Nhơn",
            Sao = 5,
            Anh = "/images/anhbenhvien/bvbinhdinh.jpg",
            Url = "https://benhvienbinhdinh.com.vn"
        },

        new
        {
            Ten = "Bệnh viện Hòa Bình",
            DiaChi = "01 Trần Hưng Đạo, TP Quy Nhơn",
            Sao = 4,
            Anh = "/images/anhbenhvien/bvhoabinh.jpg",
            Url = "https://hoabinhhospital.com.vn/  "
        },

        new
        {
            Ten = "Bệnh viện Đa khoa Thu Phúc",
            DiaChi = "418-420 Nguyễn Thái Học, TP Quy Nhơn",
            Sao = 5,
            Anh = "/images/anhbenhvien/dktp.jpg",
            Url = "https://thuphuc.vn/"
        }
    };
}

<div class="tab-container">
    <a asp-controller="CSYT"
       asp-action="BVCong"
       class="tab-item">
        Bệnh viện công lập
    </a>

    <a asp-controller="CSYT"
       asp-action="BVTu"
       class="tab-item active">
        Bệnh viện tư
    </a>
</div>
<link rel="stylesheet" href="~/css/CSYT/BVTu.css" asp-append-version="true" />
<h2 class="title">Bệnh viện tư nhân</h2>
<h3 class="subtitle">Danh sách các bệnh viện tư nhân tại Bình Định</h3>

<div class="container">
    @foreach (var bv in benhViens)
    {
        <div class="card">
            <img src="@bv.Anh" alt="Ảnh bệnh viện" />

            <h3 class="name">@bv.Ten</h3>

            <p class="address">@bv.DiaChi</p>

            <div class="stars">
                @for (int i = 0; i < bv.Sao; i++)
                {
                    <span>⭐</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(bv.Url))
            {
                <a class="btn"
                   href="@bv.Url"
                   target="_blank"
                   rel="noopener noreferrer">
                    Xem chi tiết
                </a>
            }
            else
            {
                <a class="btn" href="#">
                    Xem chi tiết
                </a>
            }
        </div>
    }
</div>