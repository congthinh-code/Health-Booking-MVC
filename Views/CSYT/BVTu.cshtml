@{
    ViewData["Title"] = "Bệnh viện tư";

    var hospitals = new[]
    {
        new {
            Name = "Bệnh viện Đa khoa tư nhân Bình Định",
            Address = "39A Phạm Ngọc Thạch, Trần Phú, Quy Nhơn",
            Rating = 5,
            Image = "/images/anhbv/bvbinhdinh.jpg",
            WebsiteUrl = "https://benhvienbinhdinh.com.vn/"
        },
        new {
            Name = "Bệnh viện Tâm Trí Quy Nhơn",
            Address = "418 Nguyễn Thị Minh Khai, Quy Nhơn",
            Rating = 4,
            Image = "/images/anhbv/bvtamtri.jpg",
            WebsiteUrl = "https://sanphukhoatamtri.vn/"
        }
    };
}

<link rel="stylesheet" href="~/css/CSYT/BVTu.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<!-- MENU TAB -->
<div class="tab-container">
    <a asp-controller="CSYT"
       asp-action="BVCong"
       class="tab-item">
        Bệnh viện công lập
    </a>

    <a asp-controller="CSYT"
       asp-action="BVTu"
       class="tab-item active">
        Bệnh viện tư
    </a>
</div>

<h2 class="title">Bệnh viện tư nhân</h2>
<h3 class="subtitle">Danh sách các bệnh viện tư nhân tại Bình Định</h3>

<div class="container">

    @if (hospitals != null && hospitals.Any())
    {
        @foreach (var bv in hospitals)
        {
            <div class="card">

                <img src="@bv.Image"
                     alt="@bv.Name">

                <h3 class="name">@bv.Name</h3>

                <p class="address">@bv.Address</p>

                <div class="stars">
                    @for (int i = 0; i < bv.Rating; i++)
                    {
                        <span>⭐</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(bv.WebsiteUrl))
                {
                    <a class="btn"
                       href="@bv.WebsiteUrl"
                       target="_blank">
                        Xem chi tiết
                    </a>
                }
                else
                {
                    <a class="btn" href="#">
                        Xem chi tiết
                    </a>
                }

            </div>
        }
    }
    else
    {
        <p>Không có dữ liệu bệnh viện tư.</p>
    }

</div>