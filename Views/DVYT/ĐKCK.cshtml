    { "Tiêu Hóa Gan Mật", ("Tiêu hoá gan mật.png", "https://medpro.vn/tim-kiem?kw=Tiêu%20Hóa%20Gan%20Mật&tab=subject&page=1") },
    { "Nội Tổng Quát", ("Nội tổng quát.png", "https://medpro.vn/tim-kiem?kw=Nội%20Tổng%20Quát&tab=subject&page=1") },
    { "Nội Tiết", ("Nội tiết.png", "https://medpro.vn/tim-kiem?kw=Nội%20Tiết&tab=subject&page=1") },
    { "Da liễu", ("Da liễu.png", "https://medpro.vn/tim-kiem?kw=Da%20Liễu&tab=subject&page=1") },
    { "Nội Tim Mạch", ("Nội tim mạch.png", "https://medpro.vn/tim-kiem?kw=Nội%20Tim%20Mạch&tab=subject&page=1") },
    { "Nội Thần Kinh", ("Nội thần kinh.png", "https://medpro.vn/tim-kiem?kw=Nội%20Thần%20Kinh&tab=subject&page=1") },
    { "Nội Cơ Xương Khớp", ("Nội cơ xương khớp.png", "https://medpro.vn/tim-kiem?kw=Nội%20Cơ%20Xương%20Khớp&tab=subject&page=1") },
    { "Tai Mũi Họng", ("Tai mũi họng.png", "https://medpro.vn/tim-kiem?kw=Tai%20Mũi%20Họng&tab=subject&page=1") },
    { "Mắt", ("Mắt.png", "https://medpro.vn/tim-kiem?kw=Mắt&tab=subject&page=1") },
    { "Nội Tiêu Hoá", ("Nội tiêu hoá.png", "https://medpro.vn/tim-kiem?kw=Nội%20Tiêu%20Hóa&tab=subject&page=1") },
    { "Nội Truyền Nhiễm", ("Nội truyền nhiễm.png", "https://medpro.vn/tim-kiem?kw=Nội%20Truyền%20Nhiễm&tab=subject&page=1") },
