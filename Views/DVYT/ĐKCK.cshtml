    { "Ngoại Cơ Xương Khớp", ("Ngoại cơ xương khớp.png", "https://medpro.vn/tim-kiem?kw=Ngoại%20Cơ%20Xương%20Khớp&tab=subject&page=1") },
    { "Sản - Phụ Khoa", ("Sản - phụ khoa.png", "https://medpro.vn/tim-kiem?kw=Sản%20-%20Phụ%20Khoa&tab=subject&page=1") }
};

}

<!DOCTYPE html>

<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đặt khám chuyên khoa</title>

    ```
    <link rel="stylesheet" href="~/css/dkck.css" />
    <link rel="icon" href="~/images/logo.png" type="image/x-icon" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    ```

</head>
<body>

    <div class="tab-container">
        <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">
            Đặt khám cơ sở
        </a>

        ```
        <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">
            Đặt khám chuyên khoa
        </a>

        <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item">
            Đặt khám bác sĩ
        </a>

        <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">
            Đặt khám ngoài giờ
        </a>

        <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">
            Thanh toán viện phí
        </a>
        ```

    </div>

    <h1 class="title">Danh sách chuyên khoa</h1>

    <div class="department-grid">

        @if (Model != null && Model.Count > 0)
        {
            @foreach (var item in Model)
            {
                string icon = "default.png";
                string link = "#";

                if (specialtyData.ContainsKey(item.Name))
                {
                    icon = specialtyData[item.Name].Icon;
                    link = specialtyData[item.Name].Link;
                }

                <a href="@link"
                   class="department-card"
                   target="_blank">

                    <img src="~/images/iconchuyenkhoa/@icon"
                         alt="@item.Name" />

                    <p>@item.Name</p>

                </a>
            }
        }
        else
        {
            <div style="text-align:center;width:100%;">
                <p>Không có dữ liệu chuyên khoa.</p>
            </div>
        }
        

    </div>

</body>
</html>
