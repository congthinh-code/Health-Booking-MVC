@model IEnumerable<Health_Booking_MVC.Models.Doctor>
@{
    ViewData["Title"] = "Đặt khám bác sĩ";
    var hospitals = ViewBag.Hospitals as IEnumerable<Health_Booking_MVC.Models.Hospital> ?? new List<Health_Booking_MVC.Models.Hospital>();
}
<link rel="stylesheet" href="~/css/DVYT/ĐKBS.css" asp-append-version="true" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item active">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">Thanh toán viện phí</a>
</div>

<section class="doctor-list">
    <h3>DANH SÁCH BÁC SĨ</h3>
    <div class="grid">
        @foreach (var doctor in Model)
        {
            <div class="doctor-card">
                @{
                    // Tự động chọn đúng thư mục chứa ảnh bác sĩ
                    var avatarPath = string.IsNullOrEmpty(doctor.Avatar)
                        ? "/images/doctor.png"
                        : (doctor.Avatar.Contains("anhbs")
                            ? $"/images/anhbacsi/{doctor.Avatar}"
                            : $"/images/userAvatar/{doctor.Avatar}");
                }
                <img src="@avatarPath" alt="@doctor.FullName" onerror="this.src='/images/doctor.png'" />
                <h4>@doctor.FullName</h4>
                <p><b>Chuyên khoa:</b> @(doctor.Specialization?.Name)</p>
                <p><b>Kinh nghiệm:</b> @doctor.ExperienceYears năm</p>
                <p><b>Chuyên môn:</b> @doctor.Description</p>

                @if (doctor.Hospital != null)
                {
                    <p><b>Nơi công tác:</b> @doctor.Hospital.Name</p>
                }

                <!-- Gọi sự kiện openModal truyền ID và Tên bác sĩ vào -->
                <button class="btn-book" onclick="openModal(@doctor.DoctorId, '@doctor.FullName')">
                    Đặt khám với bác sĩ
                </button>
            </div>
        }
    </div>
    <!-- Thêm thanh phân trang vào đây -->
    <div id="doctorPagination" class="pagination"></div>
</section>

<div id="bookingModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2>Đặt lịch khám Bác Sĩ</h2>
        <form id="bookingForm">

            <input type="text" id="patientName" placeholder="Họ và tên bệnh nhân" required />
            <input type="tel" id="phone" placeholder="Số điện thoại" required />

            <input type="hidden" id="doctorId" />
            <!-- Textbox hiện tên bác sĩ đã chọn (chỉ đọc) -->
            <input type="text" id="doctorName" readonly />

            <input type="date" id="bookingDate" required />
            <input type="time" id="bookingTime" required />

            <button type="submit">Xác nhận đặt khám</button>
        </form>
    </div>
</div>

<script>
    // Hàm mở form và gắn tên bác sĩ
    function openModal(id, name) {
        document.getElementById("bookingModal").style.display = "flex";
        document.getElementById("doctorId").value = id;
        document.getElementById("doctorName").value = name;
    }

    // Hàm đóng form
    function closeModal() {
        document.getElementById("bookingModal").style.display = "none";
        document.getElementById("bookingForm").reset();
    }

    // Bấm ra ngoài rìa đen cũng tự đóng form
    window.onclick = function (e) {
        const modal = document.getElementById("bookingModal");
        if (e.target == modal) {
            closeModal();
        }
    }

    // Xử lý khi ấn nút "Xác nhận đặt khám"
         // Xử lý khi ấn nút "Xác nhận đặt khám" (Gửi dữ liệu lên Server)
    document.getElementById("bookingForm").addEventListener("submit", function (e) {
        e.preventDefault();

        let doctorId = document.getElementById("doctorId").value;
        let patientName = document.getElementById("patientName").value;
        let phone = document.getElementById("phone").value;
        let date = document.getElementById("bookingDate").value;
        let time = document.getElementById("bookingTime").value;

        fetch('/DVYT/Book', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                doctorId: doctorId,
                patientName: patientName,
                phone: phone,
                date: date,
                time: time
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                closeModal();
                window.location.reload(); // Reload lại trang sau khi đặt thành công
            } else {
                alert("Lỗi: " + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert("Có lỗi hệ thống xảy ra khi đặt khám!");
        });
    });
    // ===================== CODE XỬ LÝ PHÂN TRANG BÁC SĨ=====================
    document.addEventListener("DOMContentLoaded", function () {
        const itemsPerPage = 4; // Cấu hình hiển thị 4 bác sĩ trên 1 trang
        const cards = Array.from(document.querySelectorAll(".doctor-card"));
        const paginationContainer = document.getElementById("doctorPagination");
        let currentPage = 1;

        function showPage(page) {
            currentPage = page;
            const startIndex = (page - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            cards.forEach((card, index) => {
                if (index >= startIndex && index < endIndex) {
                    card.style.display = ""; // Hiển thị card hợp lệ
                } else {
                    card.style.display = "none"; 
                }
            });

            updatePaginationButtons();
        }

        function updatePaginationButtons() {
            paginationContainer.innerHTML = "";
            const totalPages = Math.ceil(cards.length / itemsPerPage);

            if (totalPages <= 1) return; // Không cần phân trang nếu số bác sĩ ít hơn hoặc bằng 4

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = (i === currentPage) ? "active" : "";
                btn.addEventListener("click", function (e) {
                    e.preventDefault(); // Ngăn hành vi tải lại trang mặc định
                    showPage(i);
                });
                paginationContainer.appendChild(btn);
            }
        }

        // Khởi động trang đầu tiên
        showPage(1);
    });
</script>