@model IEnumerable<Health_Booking_MVC.Models.Doctor>
@{
    ViewData["Title"] = "Đặt khám bác sĩ";
}

<link rel="stylesheet"
      href="~/css/DVYT/ĐKBS.css"
      asp-append-version="true" />

<!-- MENU -->
<div class="tab-container">

    <a asp-controller="DVYT"
       asp-action="ĐKCS"
       class="tab-item">
        Đặt khám cơ sở
    </a>

    <a asp-controller="DVYT"
       asp-action="ĐKCK"
       class="tab-item">
        Đặt khám chuyên khoa
    </a>

    <a asp-controller="DVYT"
       asp-action="ĐKBS"
       class="tab-item active">
        Đặt khám bác sĩ
    </a>

    <a asp-controller="DVYT"
       asp-action="ĐKNG"
       class="tab-item">
        Đặt khám ngoài giờ
    </a>

    <a asp-controller="DVYT"
       asp-action="TTVP"
       class="tab-item">
        Thanh toán viện phí
    </a>

</div>

<!-- DANH SÁCH BÁC SĨ -->
<section class="content-section">

    <div class="section-title">
        DANH SÁCH BÁC SĨ
    </div>

    <div class="grid">

        @foreach (var doctor in Model)
        {
            <div class="doctor-card">

                <img src="/images/anhbacsi/@doctor.Avatar"
                     alt="@doctor.FullName"
                     onerror="this.src='/images/doctor.png'" />

                <div class="doctor-info">

                    <h4>@doctor.FullName</h4>

                    <p>
                        <b>Chuyên khoa:</b>
                        @(doctor.Specialization?.Name ?? "Chưa rõ")
                    </p>

                    <p>
                        <b>Chuyên trị:</b>
                        @(doctor.Description ?? "Không có")
                    </p>

                    <p>
                        <b>Giá khám:</b>
                        300.000 VNĐ
                    </p>

                    <div class="rating">
                        ⭐ 5.0 (100 lượt đánh giá)
                    </div>

                    <button class="btn-book"
                            onclick="openBooking('@doctor.FullName')">
                        Đặt khám với bác sĩ
                    </button>

                </div>

            </div>
        }

    </div>

</section>

<!-- FORM ĐẶT KHÁM -->
<div id="bookingModal" class="booking-overlay">

    <div class="booking-modal">

        <button type="button"
                class="booking-close"
                onclick="closeBooking()">
            &times;
        </button>

        <h3>Đặt lịch khám bác sĩ</h3>

        <p class="booking-subtitle">
            Vui lòng nhập đầy đủ thông tin để đặt lịch khám.
        </p>

        <form>

            <div class="form-field">
                <label>Tên bác sĩ</label>

                <input type="text"
                       id="doctorName"
                       readonly />
            </div>

            <div class="form-field">
                <label>Họ và tên bệnh nhân</label>

                <input type="text"
                       placeholder="Nhập họ và tên" />
            </div>

            <div class="form-field">
                <label>Số điện thoại</label>

                <input type="tel"
                       placeholder="Nhập số điện thoại" />
            </div>

            <div class="form-field">
                <label>Email</label>

                <input type="email"
                       placeholder="Nhập email" />
            </div>

            <div class="form-field">
                <label>Ngày khám</label>

                <input type="date" />
            </div>

            <div class="form-field">
                <label>Giờ khám</label>

                <input type="time" />
            </div>

            <div class="form-field">
                <label>Triệu chứng</label>

                <textarea rows="4"
                          placeholder="Mô tả triệu chứng"
                          style="width:100%;padding:12px;border:2px solid #f3c8de;border-radius:12px;"></textarea>
            </div>

            <button type="submit"
                    class="btn-submit">
                Xác nhận đặt lịch
            </button>

        </form>

    </div>

</div>

<script>

    function openBooking(doctorName) {

        document.getElementById("doctorName").value = doctorName;

        document
            .getElementById("bookingModal")
            .classList.add("show");
    }

    function closeBooking() {

        document
            .getElementById("bookingModal")
            .classList.remove("show");
    }

    window.onclick = function (event) {

        const modal = document.getElementById("bookingModal");

        if (event.target === modal) {
            closeBooking();
        }
    };

</script> 