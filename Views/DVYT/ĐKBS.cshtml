<link rel="stylesheet" href="~/css/DVYT/ĐKBS.css" asp-append-version="true" />

<!-- MENU -->
<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">
        Đặt khám cơ sở
    </a>

    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">
        Đặt khám chuyên khoa
    </a>

    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item active">
        Đặt khám bác sĩ
    </a>

    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">
        Đặt khám ngoài giờ
    </a>

    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">
        Thanh toán viện phí
    </a>
</div>

<!-- DANH SÁCH BÁC SĨ -->
<section class="doctor-list">
    <h3>DANH SÁCH BÁC SĨ</h3>

    <div class="grid">

        @foreach (var doctor in doctors)
        {
            <div class="doctor-card">

                <img src="@doctor.Avatar"
                     alt="@doctor.FullName"
                     onerror="this.src='/images/doctor.png'" />

                <h4>@doctor.FullName</h4>

                <p>
                    <b>Chuyên khoa:</b>
                    @doctor.Specialization
                </p>

                <p>
                    <b>Chuyên trị:</b>
                    @doctor.Treatment
                </p>

                <p>
                    <b>Giá khám:</b>
                    @doctor.Price
                </p>

                <div class="rating">
                    ⭐ @doctor.Rating (@doctor.Reviews lượt)
                </div>

                <button class="btn-book">
                    Đặt khám với bác sĩ
                </button>

            </div>
        }

    </div>
</section>

<!-- DANH SÁCH CƠ SỞ Y TẾ -->
<section class="clinic-list">
    <h3>Danh sách cơ sở y tế</h3>

    <div class="grid">

        @foreach (var hospital in hospitals)
        {
            <div class="clinic-card">

                <h4>@hospital.Name</h4>

                <p>@hospital.Address</p>

                <div class="rating">
                    ⭐ @hospital.Rating
                </div>

            </div>
        }

    </div>
</section>
