@model IEnumerable<Health_Booking_MVC.Models.Doctor>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Đặt khám bác sĩ";
    var hospitals = ViewBag.Hospitals as IEnumerable<Health_Booking_MVC.Models.Hospital> ?? new List<Health_Booking_MVC.Models.Hospital>();
    var isLoggedIn = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId") != null;
    var userRole = HttpContextAccessor.HttpContext?.Session.GetString("Role") ?? "";
}
<link rel="stylesheet" href="~/css/DVYT/ĐKBS.css" asp-append-version="true" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item active">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">Thanh toán viện phí</a>
</div>

@{
    var selectedDoctor = ViewBag.SelectedDoctor as Health_Booking_MVC.Models.Doctor;
}

@if (selectedDoctor != null)
{
    <style>
        .selected-doctor-container {
            width: 85%;
            margin: 0 auto 35px auto;
        }

        .selected-doctor-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 35px;
            display: flex;
            gap: 40px;
            box-shadow: 0 10px 30px rgba(214, 51, 132, 0.15);
            border: 2px solid #efb4d7;
            align-items: center;
        }

        .sd-left {
            flex: 1;
            max-width: 250px;
            text-align: center;
        }

        .sd-left img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            border-radius: 18px;
            box-shadow: 0 8px 20px rgba(76, 36, 168, 0.15);
        }

        .sd-right {
            flex: 2;
            display: flex;
            flex-direction: column;
            gap: 12px;
            text-align: left;
        }

        .sd-right h2 {
            color: #d93ba2;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 5px;
            text-align: left;
            text-transform: none;
        }

        .sd-right p {
            font-size: 16px;
            color: #444;
            margin: 0;
            text-align: left;
        }

        .sd-right p b {
            color: #4c24a8;
            font-weight: 600;
        }

        .price-tag {
            color: #d93ba2;
            font-weight: 700;
            font-size: 16px;
        }

        .rating-stars {
            color: #f5b301;
            font-weight: 700;
        }

        .btn-book-large {
            margin-top: 15px;
            width: 100%;
            max-width: 450px;
            padding: 14px 20px;
            border: none;
            border-radius: 30px;
            background: linear-gradient(95deg, #fbc2eb 0%, #a6c1ee 100%);
            color: #4c24a8;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(214, 51, 132, 0.2);
            transition: 0.3s ease;
            text-align: center;
        }

        .btn-book-large:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(214, 51, 132, 0.35);
        }

        @@media (max-width: 768px) {
            .selected-doctor-card {
                flex-direction: column;
                align-items: center;
                gap: 20px;
                padding: 20px;
            }
            .sd-left {
                max-width: 100%;
            }
            .sd-left img {
                height: 250px;
            }
            .btn-book-large {
                max-width: 100%;
            }
        }
    </style>

    <div class="selected-doctor-container">
        <div class="selected-doctor-card">
            <div class="sd-left">
                @{
                    var sdAvatarPath = string.IsNullOrEmpty(selectedDoctor.Avatar)
                        ? "/images/doctor.png"
                        : (selectedDoctor.Avatar.Contains("anhbs")
                            ? $"/images/anhbacsi/{selectedDoctor.Avatar}"
                            : $"/images/userAvatar/{selectedDoctor.Avatar}");
                }
                <img src="@sdAvatarPath" alt="@selectedDoctor.FullName" onerror="this.src='/images/doctor.png'" />
            </div>
            <div class="sd-right">
                <h2>@selectedDoctor.FullName</h2>
                <p><b>Chuyên khoa:</b> @(selectedDoctor.Specialization?.Name)</p>
                <p><b>Chuyên trị:</b> @selectedDoctor.Description</p>
                <p><b>Giá khám:</b> <span class="price-tag">230.000đ</span></p>
                <p><b>Đánh giá:</b> <span class="rating-stars">⭐ 4.9</span> (111 lượt đánh giá)</p>
                <p><b>Email:</b> @(selectedDoctor.User?.Email ?? "nguyenhuudung@healthmeet.com")</p>
                <p><b>Điện thoại:</b> @selectedDoctor.Phone</p>
                <p><b>Địa chỉ:</b> @(selectedDoctor.Hospital?.Address ?? "Bình Định")</p>
                
                <button class="btn-book-large" onclick="openModal(@selectedDoctor.DoctorId, '@selectedDoctor.FullName')">
                    Đặt khám với bác sĩ
                </button>
            </div>
        </div>
    </div>
}

<section class="doctor-list">
    <h3>DANH SÁCH BÁC SĨ</h3>
    <div class="grid">
        @foreach (var doctor in Model)
        {
            <div class="doctor-card">
                @{
                    // Tự động chọn đúng thư mục chứa ảnh bác sĩ
                    var avatarPath = string.IsNullOrEmpty(doctor.Avatar)
                        ? "/images/doctor.png"
                        : (doctor.Avatar.Contains("anhbs")
                            ? $"/images/anhbacsi/{doctor.Avatar}"
                            : $"/images/userAvatar/{doctor.Avatar}");
                }
                <img src="@avatarPath" alt="@doctor.FullName" onerror="this.src='/images/doctor.png'" />
                <h4>@doctor.FullName</h4>
                <p><b>Chuyên khoa:</b> @(doctor.Specialization?.Name)</p>
                <p><b>Kinh nghiệm:</b> @doctor.ExperienceYears năm</p>
                <p><b>Chuyên môn:</b> @doctor.Description</p>

                @if (doctor.Hospital != null)
                {
                    <p><b>Nơi công tác:</b> @doctor.Hospital.Name</p>
                }

                <!-- Gọi sự kiện openModal truyền ID và Tên bác sĩ vào -->
                <button class="btn-book" onclick="openModal(@doctor.DoctorId, '@doctor.FullName')">
                    Đặt khám với bác sĩ
                </button>
            </div>
        }
    </div>
    <!-- Thêm thanh phân trang vào đây -->
    <div id="doctorPagination" class="pagination"></div>
</section>

<div id="bookingModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2>Đặt lịch khám Bác Sĩ</h2>
        <form id="bookingForm">
            <input type="hidden" id="doctorId" />

            <div class="form-group mb-2">
                <label>Bác sĩ đã chọn</label>
                <input type="text" id="doctorName" readonly class="form-control" />
            </div>

            <div class="form-group mb-2">
                <label for="bookingDate">Ngày khám</label>
                <input type="date" id="bookingDate" required class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label for="bookingTime">Giờ khám</label>
                <input type="time" id="bookingTime" required class="form-control" />
            </div>

            <button type="submit">Xác nhận đặt khám</button>
        </form>
    </div>
</div>

<script>
    const isLoggedIn = @(isLoggedIn ? "true" : "false");
    const userRole = "@userRole";

    // Hàm mở form và gắn tên bác sĩ (Đã thêm check Đăng nhập)
    function openModal(id, name) {
        // 1. Kiểm tra nếu chưa đăng nhập
        if (!isLoggedIn) {
            if (confirm("Vui lòng đăng nhập để đặt khám bác sĩ! Bạn có muốn chuyển hướng đến trang đăng nhập không?")) {
                window.location.href = '@Url.Action("Login", "Account")';
            }
            return;
        }

        // 2. Kiểm tra nếu không phải tài khoản Bệnh nhân
        if (userRole !== "patient") {
            alert("Vui lòng đăng nhập với tài khoản Bệnh nhân để đặt khám!");
            return;
        }

        // 3. Nếu hợp lệ, hiển thị form
        document.getElementById("bookingModal").style.display = "flex";
        document.getElementById("doctorId").value = id;
        document.getElementById("doctorName").value = name;
    }

    // Hàm đóng form
    function closeModal() {
        document.getElementById("bookingModal").style.display = "none";
        document.getElementById("bookingForm").reset();
    }

    // Bấm ra ngoài rìa đen cũng tự đóng form
    window.onclick = function (e) {
        const modal = document.getElementById("bookingModal");
        if (e.target == modal) {
            closeModal();
        }
    }

    // Xử lý khi ấn nút "Xác nhận đặt khám" (Gửi dữ liệu lên Server)
    document.getElementById("bookingForm").addEventListener("submit", function (e) {
        e.preventDefault();

        let doctorId = document.getElementById("doctorId").value;
        let date = document.getElementById("bookingDate").value;
        let time = document.getElementById("bookingTime").value;

        fetch('/DVYT/Book', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                doctorId: doctorId,
                date: date,
                time: time
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                closeModal();
                window.location.reload(); // Reload lại trang sau khi đặt thành công
            } else {
                alert("Lỗi: " + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert("Có lỗi hệ thống xảy ra khi đặt khám!");
        });
    });

    // ===================== CODE XỬ LÝ PHÂN TRANG BÁC SĨ =====================
    document.addEventListener("DOMContentLoaded", function () {
        const itemsPerPage = 4; // Cấu hình hiển thị 4 bác sĩ trên 1 trang
        const cards = Array.from(document.querySelectorAll(".doctor-card"));
        const paginationContainer = document.getElementById("doctorPagination");
        let currentPage = 1;

        function showPage(page) {
            currentPage = page;
            const startIndex = (page - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            cards.forEach((card, index) => {
                if (index >= startIndex && index < endIndex) {
                    card.style.display = ""; // Hiển thị card hợp lệ
                } else {
                    card.style.display = "none";
                }
            });

            updatePaginationButtons();
        }

        function updatePaginationButtons() {
            paginationContainer.innerHTML = "";
            const totalPages = Math.ceil(cards.length / itemsPerPage);

            if (totalPages <= 1) return; // Không cần phân trang nếu số bác sĩ ít hơn hoặc bằng 4

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = (i === currentPage) ? "active" : "";
                btn.addEventListener("click", function (e) {
                    e.preventDefault(); // Ngăn hành vi tải lại trang mặc định
                    showPage(i);
                });
                paginationContainer.appendChild(btn);
            }
        }

        // Khởi động trang đầu tiên
        showPage(1);
    });
</script>