@model IEnumerable<Health_Booking_MVC.Models.Hospital>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Thanh toán viện phí";
    var isLoggedIn = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId") != null;
    var userRole = HttpContextAccessor.HttpContext?.Session.GetString("Role") ?? "";
}

<link rel="stylesheet" href="~/css/DVYT/TTVP.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item active">Thanh toán viện phí</a>
</div>

<div class="banner">
    <h1>Thanh toán viện phí</h1>
</div>

<div class="search-box">
    <input type="text" id="search" placeholder="🔍 Tìm bệnh viện..." />
</div>

<div id="list" class="benhvien-list">
    @foreach (var h in Model)
    {
        <div class="benhvien-card">
            <img src="/@h.Image" alt="@h.Name" class="benhvien-img" />
            <div class="benhvien-info">
                <h2>@h.Name</h2>
                <p>@h.Address</p>
                <div class="rating">⭐ @h.Rating / 5</div>
                <div class="benhvien-btns">
                    <a href="@h.WebsiteUrl" target="_blank" class="xem">
                        <i class="fa-solid fa-eye"></i>
                        Xem chi tiết
                    </a>
                    <button class="dat" onclick="openModal(@h.HospitalId,'@h.Name')">
                        <i class="fa-solid fa-credit-card"></i>
                        Thanh toán viện phí
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Phân trang bệnh viện -->
<div id="hospitalPagination" class="pagination"></div>

<div id="modal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2>Thanh toán viện phí</h2>
        <form id="paymentForm">
            <input type="hidden" id="hospitalId" />

            <div class="form-group mb-2">
                <label for="hospitalName">Bệnh viện</label>
                <input type="text" id="hospitalName" readonly />
            </div>

            <div class="form-group mb-2">
                <label for="billNumber">Mã hóa đơn</label>
                <input type="text" id="billNumber" placeholder="Nhập mã hóa đơn..." required />
            </div>

            <div class="form-group mb-3">
                <label for="amount">Số tiền cần thanh toán (VNĐ)</label>
                <input type="number" id="amount" placeholder="Nhập số tiền..." required />
            </div>

            <button type="button" onclick="payNow()">Xác nhận thanh toán</button>
        </form>
    </div>
</div>

<script>
    const isLoggedIn = @(isLoggedIn ? "true" : "false");
    const userRole = "@userRole";

    function openModal(id, name) {
        if (!isLoggedIn) {
            if (confirm("Vui lòng đăng nhập để thực hiện thanh toán viện phí! Bạn có muốn chuyển hướng đến trang đăng nhập?")) {
                window.location.href = '@Url.Action("Login", "Account")';
            }
            return;
        }
        if (userRole !== "patient") {
            alert("Vui lòng đăng nhập với tài khoản Bệnh nhân để thanh toán viện phí!");
            return;
        }
        document.getElementById("hospitalId").value = id;
        document.getElementById("hospitalName").value = name;
        document.getElementById("modal").classList.add("show");
    }

    function closeModal() {
        document.getElementById("modal").classList.remove("show");
        document.getElementById("paymentForm").reset();
    }

           function payNow() {
        // ➡️ Chỉ đọc mã hóa đơn và số tiền (không còn đọc Tên và SĐT)
        let billNumber = document.getElementById("billNumber").value;
        let amount = document.getElementById("amount").value;

        if (!billNumber || !amount) {
            alert("Vui lòng nhập đầy đủ thông tin!");
            return;
        }

        alert("Thanh toán thành công!\n\nMã hóa đơn: " + billNumber + "\nSố tiền: " + amount + " VNĐ");
        closeModal();
    }

    // Xử lý tìm kiếm bệnh viện
    document.getElementById("search").addEventListener("keyup", function () {
        let keyword = this.value.toLowerCase();
        let matchedCards = [];

        document.querySelectorAll(".benhvien-card").forEach(card => {
            let hospitalName = card.querySelector("h2").innerText.toLowerCase();
            if (hospitalName.includes(keyword)) {
                card.classList.add("search-match");
                matchedCards.push(card);
            } else {
                card.classList.remove("search-match");
                card.style.display = "none";
            }
        });

        // Cập nhật lại phân trang dựa trên kết quả tìm kiếm
        initPagination(matchedCards);
    });

    window.onclick = function (event) {
        let modal = document.getElementById("modal");
        if (event.target === modal) {
            closeModal();
        }
    };

    // ===================== CODE PHÂN TRANG TTVP (4 bệnh viện / trang) =====================
    const itemsPerPage = 4; // Thay đổi từ 3 thành 4 bệnh viện / trang theo yêu cầu
    let currentPage = 1;
    let activeCards = [];

    function initPagination(cardsArray) {
        activeCards = cardsArray;
        currentPage = 1;
        showPage(1);
    }

    function showPage(page) {
        currentPage = page;
        const startIndex = (page - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;

        // Ẩn toàn bộ bệnh viện trước
        document.querySelectorAll(".benhvien-card").forEach(card => card.style.display = "none");

        // Chỉ hiển thị các bệnh viện nằm trong trang hiện tại của danh sách đang active
        activeCards.slice(startIndex, endIndex).forEach(card => {
            card.style.display = "";
        });

        updatePagination();
    }

    function updatePagination() {
        const paginationContainer = document.getElementById("hospitalPagination");
        paginationContainer.innerHTML = "";
        const totalPages = Math.ceil(activeCards.length / itemsPerPage);
        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement("button");
            btn.innerText = i;
            btn.className = (i === currentPage) ? "active" : "";
            btn.addEventListener("click", function (e) {
                e.preventDefault();
                showPage(i);
            });
            paginationContainer.appendChild(btn);
        }
    }

    // Chạy phân trang ban đầu
    document.addEventListener("DOMContentLoaded", function() {
        initPagination(Array.from(document.querySelectorAll(".benhvien-card")));
    });
</script>
