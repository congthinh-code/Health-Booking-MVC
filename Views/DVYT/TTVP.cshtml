@model IEnumerable<Health_Booking_MVC.Models.Hospital>
@{
    ViewData["Title"] = "Thanh toán viện phí";
}

<link rel="stylesheet" href="~/css/DVYT/TTVP.css" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item active">Thanh toán viện phí</a>
</div>

<div class="banner">
    <h1>Thanh toán viện phí</h1>
</div>

<div class="search-box">
    <input type="text" id="search" placeholder="🔍 Tìm bệnh viện..." />
</div>

<div id="list" class="benhvien-list">
    @foreach (var h in Model)
    {
        <div class="benhvien-card">
            <img src="/@h.Image" alt="@h.Name" class="benhvien-img" />
            <div class="benhvien-info">
                <h2>@h.Name</h2>
                <p>@h.Address</p>
                <div class="rating">⭐ @h.Rating / 5</div>
                <div class="benhvien-btns">
                    <a href="@h.WebsiteUrl" target="_blank" class="xem">Xem chi tiết</a>
                    <button class="dat" onclick="openModal(@h.HospitalId,'@h.Name')">
                        Thanh toán viện phí
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<div id="modal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2>Thanh toán viện phí</h2>
        <form id="paymentForm">
            <input type="text" id="patientName" placeholder="Họ và tên" required />
            <input type="tel" id="phone" placeholder="Số điện thoại" required />
            <input type="hidden" id="hospitalId" />
            <input type="text" id="hospitalName" placeholder="Bệnh viện" readonly />
            <input type="text" id="billNumber" placeholder="Mã hóa đơn" required />
            <input type="number" id="amount" placeholder="Số tiền cần thanh toán" required />
            <button type="button" onclick="payNow()">Xác nhận thanh toán</button>
        </form>
    </div>
</div>

<script>
    function openModal(id, name) {
        document.getElementById("hospitalId").value = id;
        document.getElementById("hospitalName").value = name;
        document.getElementById("modal").classList.add("show");
    }

    function closeModal() {
        document.getElementById("modal").classList.remove("show");
        document.getElementById("paymentForm").reset();
    }

    function payNow() {
        let patientName = document.getElementById("patientName").value;
        let phone = document.getElementById("phone").value;
        let billNumber = document.getElementById("billNumber").value;
        let amount = document.getElementById("amount").value;

        if (!patientName || !phone || !billNumber || !amount) {
            alert("Vui lòng nhập đầy đủ thông tin!");
            return;
        }

        alert("Thanh toán thành công!\n\nBệnh nhân: " + patientName + "\nMã hóa đơn: " + billNumber + "\nSố tiền: " + amount + " VNĐ");
        closeModal();
    }

    document.getElementById("search").addEventListener("keyup", function () {
        let keyword = this.value.toLowerCase();
        document.querySelectorAll(".benhvien-card").forEach(card => {
            let hospitalName = card.querySelector("h2").innerText.toLowerCase();
            if (hospitalName.includes(keyword)) {
                card.style.display = "";
            } else {
                card.style.display = "none";
            }
        });
    });

    window.onclick = function (event) {
        let modal = document.getElementById("modal");
        if (event.target === modal) {
            closeModal();
        }
    };
</script>