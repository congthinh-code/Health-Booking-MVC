@model IEnumerable<Health_Booking_MVC.Models.Hospital>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Đặt khám ngoài giờ";
    var doctors = ViewBag.Doctors as IEnumerable<Health_Booking_MVC.Models.Doctor> ?? new List<Health_Booking_MVC.Models.Doctor>();
    var isLoggedIn = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId") != null;
    var userRole = HttpContextAccessor.HttpContext?.Session.GetString("Role") ?? "";
}
<link rel="stylesheet" href="~/css/DVYT/ĐKNG.css" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item active">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">Thanh toán viện phí</a>
</div>

<div class="page-header">
    <h1 class="page-title">ĐẶT LỊCH KHÁM NGOÀI GIỜ</h1>
</div>

<section class="hospital-list">
    <h3 class="page-title">Danh sách bệnh viện</h3>

    <div id="hospitalGrid" class="grid">
        @foreach (var bv in Model)
        {
            <div class="card">
                <div class="card-left">
                    <img src="/@bv.Image" class="logo" alt="@bv.Name" />
                </div>
                <div class="card-right">
                    <h3 class="title">
                        @bv.Name
                        <span class="verified">✓</span>
                    </h3>
                    <p class="address">@bv.Address</p>
                    <div class="rating">
                        <span class="score">(@bv.Rating)</span>
                        <span class="stars">
                            @for (int i = 0; i < bv.Rating; i++)
                            {
                                @:★
                            }
                        </span>
                    </div>
                    <div class="card-actions">
                        <a href="#" class="btn outline">Xem chi tiết</a>
                        <button type="button" class="btn primary" onclick="openModal(@bv.HospitalId,'@bv.Name')">
                            Đặt khám
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
    <div id="hospitalPagination" class="pagination"></div>
</section>

<div id="modal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2>Đặt lịch khám ngoài giờ</h2>
        <form id="bookingForm">
            <input type="hidden" id="hospital_id" />

            <div class="form-group">
                <label for="hospital_name">Cơ sở y tế</label>
                <input type="text" id="hospital_name" readonly />
            </div>

            <div class="form-group">
                <label for="patientName">Họ và tên bệnh nhân</label>
                <input type="text" id="patientName" placeholder="Họ và tên" required />
            </div>

            <div class="form-group">
                <label for="phone">Số điện thoại</label>
                <input type="tel" id="phone" placeholder="Số điện thoại" required />
            </div>

            <div class="form-group">
                <label for="doctorSelect">Chọn bác sĩ khám</label>
                <select id="doctorSelect" required>
                    <option value="">-- Chọn bác sĩ --</option>
                    @foreach (var doctor in doctors)
                    {
                        <option value="@doctor.DoctorId">@doctor.FullName</option>
                    }
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Ngày khám</label>
                    <input type="date" required />
                </div>
                <div class="form-group">
                    <label>Giờ khám</label>
                    <input type="time" required />
                </div>
            </div>

            <button type="submit">Xác nhận đặt khám</button>
        </form>
    </div>
</div>

<script>
    const isLoggedIn = @(isLoggedIn ? "true" : "false");
    const userRole = "@userRole";

    function openModal(id, name) {
        if (!isLoggedIn) {
            if (confirm("Vui lòng đăng nhập để thực hiện chức năng đặt khám! Bạn có muốn chuyển hướng đến trang đăng nhập?")) {
                window.location.href = '@Url.Action("Login", "Account")';
            }
            return;
        }
        if (userRole !== "patient") {
            alert("Vui lòng đăng nhập với tài khoản Bệnh nhân để đặt khám!");
            return;
        }
        document.getElementById("hospital_id").value = id;
        document.getElementById("hospital_name").value = name;
        document.getElementById("modal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("modal").style.display = "none";
        document.getElementById("bookingForm").reset();
    }

    document.getElementById("bookingForm").addEventListener("submit", function (e) {
        e.preventDefault();
        if (!isLoggedIn) {
            alert("Vui lòng đăng nhập để đặt khám!");
            return;
        }
        if (userRole !== "patient") {
            alert("Vui lòng đăng nhập với tài khoản Bệnh nhân để đặt khám!");
            return;
        }
        let patient = document.getElementById("patientName").value;
        alert("Đặt lịch thành công!\n\nBệnh nhân: " + patient);
        closeModal();
    });

    window.onclick = function (event) {
        let modal = document.getElementById("modal");
        if (event.target === modal) {
            closeModal();
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const itemsPerPage = 3;
        const cards = Array.from(document.querySelectorAll("#hospitalGrid .card"));
        const paginationContainer = document.getElementById("hospitalPagination");
        let currentPage = 1;

        function showPage(page) {
            currentPage = page;
            const startIndex = (page - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            cards.forEach((card, index) => {
                if (index >= startIndex && index < endIndex) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });

            updatePagination();
        }

        function updatePagination() {
            paginationContainer.innerHTML = "";
            const totalPages = Math.ceil(cards.length / itemsPerPage);
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = (i === currentPage) ? "active" : "";
                btn.addEventListener("click", function (e) {
                    e.preventDefault();
                    showPage(i);
                });
                paginationContainer.appendChild(btn);
            }
        }

        showPage(1);
    });
</script>