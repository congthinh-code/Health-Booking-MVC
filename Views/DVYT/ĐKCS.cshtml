@{
    ViewData["Title"] = "Đặt khám tại cơ sở";
var benhviens = new[]
{
    new {
        Id = 1,
        Ten = "Bệnh viện Đa khoa Bình Định",
        DiaChi = "106 Nguyễn Huệ, TP. Quy Nhơn",
        Sao = 5,
        Anh = "/images/hospital/bvdkbinhdinh.jpg",
        Url = "https://benhviendakhoabinhdinh.vn"
    },

    new {
        Id = 2,
        Ten = "Bệnh viện Quân Y 13",
        DiaChi = "01 Nguyễn Thái Học, TP. Quy Nhơn",
        Sao = 4,
        Anh = "/images/hospital/quany13.jpg",
        Url = "https://bvquany13.vn"
    },

    new {
        Id = 3,
        Ten = "Bệnh viện Mắt Bình Định",
        DiaChi = "12 Lê Lợi, TP. Quy Nhơn",
        Sao = 5,
        Anh = "/images/hospital/matbinhdinh.jpg",
        Url = "#"
    },

    new {
        Id = 4,
        Ten = "Bệnh viện Da Liễu Bình Định",
        DiaChi = "08 Trần Hưng Đạo, TP. Quy Nhơn",
        Sao = 4,
        Anh = "/images/hospital/dalieu.jpg",
        Url = "#"
    }
};

    var specialties = new[]
    {
    new { Id = 1, Name = "Tim mạch" },
    new { Id = 2, Name = "Da liễu" },
    new { Id = 3, Name = "Tai Mũi Họng" },
    new { Id = 4, Name = "Mắt" },
    new { Id = 5, Name = "Nội tổng quát" }
};


}

<link rel="stylesheet" href="~/css/DVYT/ĐKCS.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item active">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">Thanh toán viện phí</a>
</div>
<div class="dkcs-container">

    <h1>ĐẶT KHÁM TẠI CƠ SỞ Y TẾ - BÌNH ĐỊNH</h1>

    <div class="benhvien-list">

        @foreach (var bv in benhviens)
        {
            <div class="benhvien-card">

                <img src="@bv.Anh"
                     class="benhvien-img"
                     alt="@bv.Ten" />

                <div class="benhvien-info">

                    <h2>@bv.Ten</h2>

                    <p>
                        <i class="fa-solid fa-location-dot"></i>
                        @bv.DiaChi
                    </p>

                    <div class="rating">
                        @for (int i = 0; i < bv.Sao; i++)
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                    </div>

                    <div class="benhvien-btns">

                        <a class="xem"
                           href="@bv.Url"
                           target="_blank">
                            <i class="fa-solid fa-eye"></i>
                            Xem chi tiết
                        </a>

                        <button class="dat"
                                onclick="openBookingFromHospital(@bv.Id)">
                            <i class="fa-solid fa-calendar-check"></i>
                            Đặt khám ngay
                        </button>

                    </div>

                </div>

            </div>
        }

    </div>
   
</div>

<div id="bookingModal" class="modal">
    <div class="modal-content">

        <span class="close"
              onclick="closeBooking()">
            &times;
        </span>

        <h2>Đặt lịch khám</h2>

        <form id="bookingForm">

            <input type="text"
                   placeholder="Họ và tên"
                   required />

            <input type="tel"
                   placeholder="Số điện thoại"
                   required />

            <select id="hospitalSelect">

                <option value="">
                    -- Chọn bệnh viện --
                </option>

                @foreach (var bv in benhviens)
                {
                    <option value="@bv.Id">
                        @bv.Ten
                    </option>
                }

            </select>

            <select>

                <option value="">
                    -- Chọn chuyên khoa --
                </option>

                @foreach (var s in specialties)
                {
                    <option value="@s.Id">
                        @s.Name
                    </option>
                }

            </select>

            <input type="date" required />

            <input type="time" required />

            <button type="submit">
                Xác nhận đặt khám
            </button>

        </form>

    </div>

</div>

<script>
    function openBookingFromHospital(id) {
        document.getElementById("bookingModal").style.display = "flex";
        document.getElementById("hospitalSelect").value = id;
    }

    function closeBooking() {
        document.getElementById("bookingModal").style.display = "none";
    }

    window.onclick = function (e) {
        const modal = document.getElementById("bookingModal");

        if (e.target == modal) {
            closeBooking();
        }
    }

    document.getElementById("bookingForm")
    .addEventListener("submit", function (e) {

        e.preventDefault();

        alert("Đặt lịch khám thành công!");
        closeBooking();
    });
</script>
