@model IEnumerable<Health_Booking_MVC.Models.Hospital>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Đặt khám tại cơ sở";
    var isLoggedIn = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId") != null;
    var userRole = HttpContextAccessor.HttpContext?.Session.GetString("Role") ?? "";

}

<link rel="stylesheet" href="~/css/DVYT/ĐKCS.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="tab-container">
    <a asp-controller="DVYT" asp-action="ĐKCS" class="tab-item active">Đặt khám cơ sở</a>
    <a asp-controller="DVYT" asp-action="ĐKCK" class="tab-item">Đặt khám chuyên khoa</a>
    <a asp-controller="DVYT" asp-action="ĐKBS" class="tab-item">Đặt khám bác sĩ</a>
    <a asp-controller="DVYT" asp-action="ĐKNG" class="tab-item">Đặt khám ngoài giờ</a>
    <a asp-controller="DVYT" asp-action="TTVP" class="tab-item">Thanh toán viện phí</a>
</div>
<div class="dkcs-container">

    <h1>ĐẶT KHÁM TẠI CƠ SỞ Y TẾ - BÌNH ĐỊNH</h1>

    <div id="hospitalGrid" class="benhvien-list">
        @foreach (var bv in Model)
        {
            <div class="benhvien-card">
                <img src="/@bv.Image" class="benhvien-img" alt="@bv.Name" />
                <div class="benhvien-info">
                    <h2>@bv.Name</h2>
                    <p>
                        <i class="fa-solid fa-location-dot"></i>
                        @bv.Address
                    </p>
                    <div class="rating">
                        @for (int i = 0; i < bv.Rating; i++)
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                    </div>
                    <div class="benhvien-btns">
                        <a class="xem" href="@bv.WebsiteUrl" target="_blank">
                            <i class="fa-solid fa-eye"></i>
                            Xem chi tiết
                        </a>
                        <button class="dat" onclick="openBookingFromHospital(@bv.HospitalId)">
                            <i class="fa-solid fa-calendar-check"></i>
                            Đặt khám ngay
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
    <!-- Phân trang bệnh viện -->
    <div id="hospitalPagination" class="pagination"></div>
</div>

<div id="bookingModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeBooking()">&times;</span>
        <h2>Đặt lịch khám</h2>
        <form id="bookingForm">
            <input type="hidden" name="hospital_id" id="hospital_id" />

            <div class="form-group mb-2">
                <label>Bệnh viện</label>
                <select id="hospitalSelect" class="form-select" disabled>
                    <option value="">-- Chọn bệnh viện --</option>
                    @foreach (var bv in Model)
                    {
                        <option value="@bv.HospitalId">@bv.Name</option>
                    }
                </select>
            </div>

            <div class="form-group mb-2">
                <label for="bookingDate">Ngày khám</label>
                <input type="date" id="bookingDate" required class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label for="bookingTime">Giờ khám</label>
                <input type="time" id="bookingTime" required class="form-control" />
            </div>

            <button type="submit" class="btn-submit">Xác nhận đặt khám</button>
        </form>
    </div>
</div>

<script>
    const isLoggedIn = @(isLoggedIn ? "true" : "false");
    const userRole = "@userRole";

    function openBookingFromHospital(id) {
        if (!isLoggedIn) {
            if (confirm("Vui lòng đăng nhập để thực hiện chức năng đặt khám! Bạn có muốn chuyển hướng đến trang đăng nhập?")) {
                window.location.href = '@Url.Action("Login", "Account")';
            }
            return;
        }
        if (userRole !== "patient") {
            alert("Vui lòng đăng nhập với tài khoản Bệnh nhân để đặt khám!");
            return;
        }
        document.getElementById("bookingModal").style.display = "flex";
        document.getElementById("hospitalSelect").value = id;
        document.getElementById("hospital_id").value = id;
    }

    function closeBooking() {
        document.getElementById("bookingModal").style.display = "none";
        document.getElementById("bookingForm").reset();
    }

    window.onclick = function (e) {
        const modal = document.getElementById("bookingModal");
        if (e.target == modal) {
            closeBooking();
        }
    }

    // Khóa ngày quá khứ & Validate thời gian
    const dateInput = document.getElementById("bookingDate");
    const timeInput = document.getElementById("bookingTime");

    if (dateInput) {
        const today = new Date().toISOString().split('T')[0];
        dateInput.min = today;
        dateInput.addEventListener("change", validateDateTime);
    }

    if (timeInput) {
        timeInput.addEventListener("change", validateDateTime);
    }

    function validateDateTime() {
        if (!dateInput.value || !timeInput.value) return true;

        const selectedDateTime = new Date(`${dateInput.value}T${timeInput.value}`);
        const currentDateTime = new Date();

        if (selectedDateTime < currentDateTime) {
            alert("Thời gian đặt khám không được nhỏ hơn giờ hiện tại của ngày hôm nay!");
            timeInput.value = "";
            return false;
        }
        return true;
    }

    document.getElementById("bookingForm").addEventListener("submit", function (e) {
        e.preventDefault();
        if (!isLoggedIn) {
            alert("Vui lòng đăng nhập để đặt khám!");
            return;
        }
        if (userRole !== "patient") {
            alert("Vui lòng đăng nhập với tài khoản Bệnh nhân để đặt khám!");
            return;
        }

        if (!validateDateTime()) return;

        let hospitalId = document.getElementById("hospital_id").value;
        let date = document.getElementById("bookingDate").value;
        let time = document.getElementById("bookingTime").value;

        const submitBtn = this.querySelector(".btn-submit");
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerText = "Đang xử lý...";
        }

        fetch('/Booking/ProcessBooking', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                hospital_id: hospitalId,
                appointment_date: date,
                appointment_time: time
            })
        })
        .then(response => {
            if (!response.ok) {
                throw new Error("Lỗi hệ thống từ Server");
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                alert(data.message);
                closeBooking();
                window.location.reload();
            } else {
                alert("Lỗi: " + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert("Có lỗi hệ thống xảy ra khi đặt khám!");
        })
        .finally(() => {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerText = "Xác nhận đặt khám";
            }
        });
    });

    // ===================== CODE PHÂN TRANG ĐKCS =====================
    document.addEventListener("DOMContentLoaded", function () {
        const itemsPerPage = 3;
        const cards = Array.from(document.querySelectorAll(".benhvien-card"));
        const paginationContainer = document.getElementById("hospitalPagination");
        let currentPage = 1;

        function showPage(page) {
            currentPage = page;
            const startIndex = (page - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            cards.forEach((card, index) => {
                if (index >= startIndex && index < endIndex) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });
            updatePagination();
        }

        function updatePagination() {
            paginationContainer.innerHTML = "";
            const totalPages = Math.ceil(cards.length / itemsPerPage);
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = (i === currentPage) ? "active" : "";
                btn.addEventListener("click", function (e) {
                    e.preventDefault();
                    showPage(i);
                });
                paginationContainer.appendChild(btn);
            }
        }

        showPage(1);
    });
</script>