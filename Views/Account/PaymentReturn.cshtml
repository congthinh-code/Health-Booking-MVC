@{
    ViewData["Title"] = "Kết quả thanh toán lịch hẹn";
}

<div class="container mt-5" style="max-width: 580px;">
    <div class="card shadow border-0 p-4 text-center bg-white">
        @if (ViewBag.IsSuccess == true)
        {
            <div class="text-success mb-3">
                <i class="fa-solid fa-circle-check" style="font-size: 4.5rem;"></i>
            </div>
            <h3 class="fw-bold text-dark mb-1">Thanh Toán Thành Công!</h3>
            <p class="text-muted small">Cổng thanh toán thử nghiệm VNPay Sandbox đã ghi nhận</p>

            <div class="bg-light p-3 rounded-3 my-4 text-start small">
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span class="text-muted">Nội dung thanh toán:</span>
                    <span class="fw-semibold text-dark">@ViewBag.OrderInfo</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span class="text-muted">Ngân hàng xử lý:</span>
                    <span class="fw-bold text-primary">@ViewBag.Bank</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span class="text-muted">Mã giao dịch VNPay:</span>
                    <span class="fw-mono text-dark">#@ViewBag.TransactionNo</span>
                </div>
                <div class="d-flex justify-content-between pt-1">
                    <span class="text-dark fw-bold">Tổng tiền thanh toán:</span>
                    <span class="fw-bold text-success fs-5">@ViewBag.Amount</span>
                </div>
            </div>
        }
        else
        {
            <div class="text-danger mb-3">
                <i class="fa-solid fa-circle-xmark" style="font-size: 4.5rem;"></i>
            </div>
            <h3 class="fw-bold text-dark mb-1">Thanh Toán Thất Bại</h3>
            <p class="text-muted small">@ViewBag.Message</p>
        }

        <div class="d-grid gap-2 mt-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill py-2 fw-semibold">
                <i class="fa-solid fa-house me-1"></i> Quay lại Trang chủ
            </a>
        </div>
    </div>
</div>