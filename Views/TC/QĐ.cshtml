<link rel="stylesheet" href="~/css/TC/QĐ.css" />

<body class="page-sudung">

    <header class="usage-hero">
        <div class="container">
            <img src="~/images/logo.png" alt="HealthMeet Logo" class="logo">
            <h1>Quy định Sử dụng Phần mềm HEALTHBOOKING</h1>
        </div>
    </header>

    <main class="container usage-content">

        @foreach (var itemSection in sections)
        {
            <section>
                <h2>@itemSection.Key</h2>

                <ul>
                    @foreach (var item in itemSection.Value)
                    {
                        <li>@item</li>
                    }
                </ul>
            </section>
        }

    </main>

</body>