@model Health_Booking_MVC.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Trang Chủ";
}

<link rel="stylesheet" href="~/css/index.css" />

<!-- HERO -->
<section class="hero">

    <!-- Video nền -->
    <video autoplay muted loop playsinline class="hero-video">
        <source src="~/video/nen.mp4" type="video/mp4">
    </video>

    <!-- Nội dung hero -->
    <div class="hero-content">
        <h1>Đặt lịch khám nhanh chóng</h1>
        <div class="search-container">
            <input type="text"
                   id="searchInput"
                   class="search"
                   placeholder="Tìm kiếm bác sĩ, chuyên khoa, bệnh viện...">

            <div id="searchResults" class="search-results"></div>
        </div>

        <ul class="hero-list">
            <li>✔ Đặt khám nhanh - lấy số thứ tự online</li>
            <li>✔ Đặt khám theo giờ - chọn khung giờ thuận tiện</li>
            <li>✔ Hoàn tiền khi hủy khám</li>
        </ul>

        <button class="btn-book" onclick="openBooking()">
            ĐẶT LỊCH NGAY
        </button>
    </div>
</section>

@* Modal đặt lịch *@
<div id="bookingModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeBooking()">&times;</span>
        <h2>Đặt Lịch Khám</h2>
        <form id="bookingForm">
            <label>Họ và Tên:</label>
            <input type="text" name="patient_name" id="patient_name" required>
            <label>Số điện thoại:</label>
            <input type="tel" name="phone" id="phone" required pattern="[0-9]{10,11}" placeholder="0123456789">
            <label>Bệnh viện:</label>
            <select name="hospital_id" id="hospital_id">
                <option value="">-- Chọn bệnh viện --</option>

                @foreach (var item in Model.Hospitals)
                {
                    <option value="@item.HospitalId">
                        @item.Name
                    </option>
                }
            </select>
            <label>Chuyên khoa:</label>
            <select name="specialization_id" id="specialization_id">
                <option value="">-- Chọn chuyên khoa --</option>

                @foreach (var item in Model.Specializations)
                {
                    <option value="@item.SpecializationId">
                        @item.Name
                    </option>
                }
            </select>
            <label>Ngày khám:</label>
            <input type="date" name="appointment_date" id="appointment_date" required min="<?= date('Y-m-d') ?>">
            <label>Giờ khám:</label>
            <input type="time" name="appointment_time" id="appointment_time" required>
            <button type="submit" class="btn-submit">Xác nhận đặt lịch</button>
        </form>
    </div>
</div>

<!-- DỊCH VỤ -->
<section class="services">
    <div class="container">
        <div class="cards">
            <a href="#">
                <div class="card" onclick="window.location.href='/DVYT/ĐKCS'">
                    📅
                    <p>Đặt khám tại cơ sở</p>
                </div>
            </a>

            <a href="#">
                <div class="card" onclick="window.location.href='/DVYT/ĐKCK'">
                    💊
                    <p>Đặt khám chuyên khoa</p>
                </div>
            </a>

            <a href="#">
                <div class="card" onclick="window.location.href='/DVYT/ĐKBS'">
                    👨‍⚕️
                    <p>Đặt khám theo bác sĩ</p>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- CHUYÊN KHOA -->
<section class="specialties">
    <h2>CHUYÊN KHOA</h2>
    <div class="grid">
        @foreach (var item in Model.Specializations)
        {
            <a class="item" href="https://medpro.vn/tim-kiem?kw=@(item.Name.Replace(" - ", " "))&tab=subject&page=1" target="_blank" rel="noopener noreferrer">
                <img src="~/images/iconchuyenkhoa/@(item.Name).png" alt="@item.Name" onerror="this.src='/images/logo.png'">
                <p>@item.Name</p>
            </a>
        }
    </div>
</section>

<script src="~/js/search.js"></script>
<script src="~/js/home.js"></script>
