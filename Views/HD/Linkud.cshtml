@{
    ViewData["Title"] = "Tải ứng dụng HealthMeet";
}

<link rel="stylesheet" href="~/css/HD/linkud.css" />

<!-- TAB MENU -->

<div class="tab-container">

    <a asp-controller="HD"
       asp-action="CĐ"
       class="tab-item">
        Cài đặt ứng dụng
    </a>

    <a asp-controller="HD"
       asp-action="QTHP"
       class="tab-item">
        Quy trình hoàn phí
    </a>

    <a asp-controller="HD"
       asp-action="CHTG"
       class="tab-item">
        Câu hỏi thường gặp
    </a>

    <a asp-controller="HD"
       asp-action="QTĐK"
       class="tab-item">
        Quy trình đi khám
    </a>

</div>

<!-- HEADER -->

<header class="site-header">
    <div class="container">
        <h1 class="logo">
            TẢI ỨNG DỤNG ĐẶT KHÁM NHANH
            <span class="brand">HEALTHMEET</span>
        </h1>

        <div class="store-buttons">
            <a class="btn-store">
                App Store
            </a>

            <a class="btn-store">
                Google Play
            </a>
        </div>
    </div>
</header>

<!-- MAIN -->

<main class="hero">
    <div class="container hero-grid">
        <!-- LEFT -->

        <div class="features col-left">
            <div class="feature">
                <div class="icon">
                    <i class="fa-solid fa-user-check"></i>
                </div>

                <div>
                    <h3>Lấy số thứ tự khám nhanh trực tuyến</h3>
                    <p>
                        Đăng ký khám / tái khám nhanh theo ngày,
                        đặt khám theo bác sĩ chuyên khoa.
                    </p>
                </div>
            </div>

            <div class="feature">
                <div class="icon">
                    <i class="fa-solid fa-comments"></i>
                </div>

                <div>
                    <h3>Tư vấn sức khỏe từ xa</h3>

                    <p>
                        Cuộc gọi video với bác sĩ chuyên môn,
                        tư vấn nhanh gọn.
                    </p>
                </div>
            </div>

            <div class="feature">
                <div class="icon">
                    <i class="fa-solid fa-file-medical"></i>
                </div>

                <div>
                    <h3>Tra cứu kết quả cận lâm sàng</h3>
                    <p>
                        Tra cứu kết quả trực tuyến dễ dàng và tiện lợi.
                    </p>
                </div>
            </div>
        </div>

        <!-- PHONE -->

        <div class="phone-wrap">
            <div class="phone-frame">
                <img src="~/images/header/anhđt.jpg"
                     alt="HealthMeet App Preview">
            </div>
        </div>

        <!-- RIGHT -->

        <div class="features col-right">
            <div class="feature">
                <div class="icon">
                    <i class="fa-solid fa-credit-card"></i>
                </div>

                <div>
                    <h3>Thanh toán viện phí</h3>

                    <p>
                        Hỗ trợ nhiều cổng thanh toán trực tuyến.
                    </p>
                </div>
            </div>

            <div class="feature">
                <div class="icon">
                    <i class="fa-solid fa-house-medical"></i>
                </div>

                <div>
                    <h3>Chăm sóc Y tế tại nhà</h3>
                    <p>
                        Dịch vụ điều dưỡng, xét nghiệm tại nhà,
                        đáp ứng nhu cầu phổ thông.
                    </p>
                </div>
            </div>

            <div class="feature">

                <div class="icon">
                    <i class="fa-solid fa-network-wired"></i>
                </div>

                <div>

                    <h3>Mạng lưới Cơ sở hợp tác</h3>

                    <p>
                        Kết nối rộng khắp bệnh viện,
                        phòng khám trên toàn quốc.
                    </p>

                </div>
            </div>
        </div>
    </div>
</main>

<!-- FOOTER DEMO -->

<footer class="site-footer">
    <div class="container">
        <p>
            © @DateTime.Now.Year HEALTHMEET — Demo giao diện
        </p>
    </div>
</footer>

<!-- SUPPORT -->

<section class="support-container">

    <div class="support-left">
        <img src="~/images/header/anhbia.jpg"
             alt="Doctor"
             class="doctor-img">
    </div>

    <div class="support-right">

        <h2>CÁC HÌNH THỨC HỖ TRỢ</h2>

        <p class="hotline">
            1900-2005
        </p>

        <div class="qr-group">
            <div class="qr-item">
                <img src="~/images/header/qrZalo.jpg"
                     alt="QR Zalo">
                <p>Zalo</p>
            </div>

            <div class="qr-item">
                <img src="~/images/header/qrFB.jpg"
                     alt="QR Facebook">

                <p>Facebook</p>
            </div>
        </div>
    </div>
</section>