@{
    ViewData["Title"] = "Hướng dẫn cài đặt ứng dụng";
}

<link rel="stylesheet" href="~/css/HD/CĐ.css" />

<!-- MENU TAB -->
<div class="tab-container">
    <a asp-controller="HD"
       asp-action="CĐ"
       class="tab-item active">
        Cài đặt ứng dụng
    </a>

    <a asp-controller="HD"
       asp-action="QTHP"
       class="tab-item">
        Quy trình hoàn phí
    </a>

    <a asp-controller="HD"
       asp-action="CHTG"
       class="tab-item">
        Câu hỏi thường gặp
    </a>

    <a asp-controller="HD"
       asp-action="QTĐK"
       class="tab-item">
        Quy trình đi khám
    </a>
</div>

<!-- =============================== -->
<!-- PHẦN 1 -->
<!-- =============================== -->

<section class="install-container">

    <h1>Hướng dẫn cài đặt ứng dụng</h1>
    <p class="subtitle">
        Khám phá cách đơn giản và nhanh chóng để cài đặt ứng dụng y tế số HealthMeet
    </p>

    <div class="install-box">
        <ul>
            <li>
                <strong>Cách 1:</strong>
                Tải ứng dụng:
                <a asp-controller="HD"
                   asp-action="Linkud">
                    Hướng dẫn ứng dụng
                </a>
            </li>

            <li>
                <strong>Cách 2:</strong>
                Tìm kiếm “HealthMeet” trên App Store hoặc Google Play
            </li>

            <li>
                <strong>Cách 3:</strong>
                Quét mã QR
            </li>
        </ul>

        <div class="qr-center">
            <img src="~/images/anhqr.jpg"
                 alt="QR HealthMeet" />
        </div>
    </div>
</section>

<!-- =============================== -->
<!-- PHẦN 2 -->
<!-- =============================== -->

<section class="support-container">
    <div class="support-left">
        <img src="~/images/anhbia.jpg"
             alt="Doctor"
             class="doctor-img" />
    </div>

    <div class="support-right">
        <h2>CÁC HÌNH THỨC HỖ TRỢ</h2>

        <p class="hotline">
            1900-2005
        </p>

        <div class="qr-group">
            <div class="qr-item">
                <img src="~/images/qrZalo.jpg"
                     alt="QR Zalo" />
                <p>Zalo</p>
            </div>

            <div class="qr-item">
                <img src="~/images/qrFB.jpg"
                     alt="QR Facebook" />
                <p>Facebook</p>
            </div>
        </div>
    </div>
</section>