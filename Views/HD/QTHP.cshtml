@{
    ViewData["Title"] = "Quy trình hoàn phí";
}

<link rel="stylesheet" href="~/css/HD/QTHP.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<!-- MENU TAB -->
<div class="tab-container">
    <a asp-controller="HD"
       asp-action="CĐ"
       class="tab-item">
        Cài đặt ứng dụng
    </a>

    <a asp-controller="HD"
       asp-action="QTHP"
       class="tab-item active">
        Quy trình hoàn phí
    </a>

    <a asp-controller="HD"
       asp-action="CHTG"
       class="tab-item">
        Câu hỏi thường gặp
    </a>

    <a asp-controller="HD"
       asp-action="QTĐK"
       class="tab-item">
        Quy trình đi khám
    </a>
</div>

<!-- TIÊU ĐỀ -->
<h1 class="title">Quy trình hoàn phí an toàn & minh bạch</h1>

<p class="subtitle">
    Chi tiết về cách chúng tôi đảm bảo quyền lợi cho khách hàng
</p>

<!-- KHUNG NỘI DUNG -->
<div class="content-box">

    <h2 class="section-title">Điều kiện để được hoàn tiền</h2>

    <ul class="list">
        <li>
            Bạn chỉ được hoàn tiền khi thực hiện thành công yêu cầu hủy
            Phiếu Khám Bệnh trên ứng dụng theo quy định.
        </li>
    </ul>

    <h2 class="section-title">Các bước hoàn tiền</h2>

    <ul class="list">
        <li>
            Khi bạn thực hiện việc thanh toán bằng phương thức nào,
            thì ứng dụng sẽ hoàn tiền lại cho bạn đúng phương thức
            và số tài khoản đã dùng để thanh toán đó.
        </li>
    </ul>

    <h2 class="section-title">Thời gian hoàn tiền</h2>

    <ul class="list">
        <li>Thẻ khám bệnh: 1 - 30 ngày làm việc</li>
        <li>Thẻ ATM nội địa: 1 - 30 ngày làm việc</li>
        <li>Thẻ tín dụng Visa, MasterCard: 1 - 45 ngày làm việc</li>
    </ul>

    <p class="note">
        Tính từ thời điểm bạn thực hiện Hủy Phiếu Khám Bệnh thành công,
        nếu quá thời gian trên bạn vẫn chưa nhận được tiền hoàn,
        vui lòng liên hệ tổng đài 1900-2005 để được hỗ trợ.
    </p>

</div>

<!-- HỖ TRỢ -->
<section class="support-container">

    <div class="support-left">
        <img src="~/images/anhbia.jpg"
             alt="Doctor"
             class="doctor-img">
    </div>

    <div class="support-right">

        <h2>CÁC HÌNH THỨC HỖ TRỢ</h2>

        <p class="hotline">1900-2005</p>

        <div class="qr-group">

            <div class="qr-item">
                <img src="~/images/qrZalo.jpg" alt="QR Zalo">
                <p>Zalo</p>
            </div>

            <div class="qr-item">
                <img src="~/images/qrFB.jpg" alt="QR Facebook">
                <p>Facebook</p>
            </div>

        </div>
    </div>

</section>