@model Health_Booking_MVC.Models.ViewModels.PatientProfileViewModel

@{
    ViewData["Title"] = "Trang cá nhân";
}

<link rel="stylesheet" href="~/css/patient.css" />

<div class="container-patient">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="card">
            <div class="sidebar-avatar">

                @if (!string.IsNullOrEmpty(Model.Avatar))
                {
                    <img src="@Model.Avatar" />
                }
                else
                {
                    <img src="~/images/default-avatar.png" />
                }

                <div class="camera-btn"
                     onclick="document.getElementById('avatarInput').click()">
                    <i class="bi bi-camera-fill"></i>
                </div>

                <form id="avatarForm"
                      asp-action="UploadAvatar"
                      asp-controller="Patient"
                      method="post"
                      enctype="multipart/form-data">

                    <input type="file"
                           id="avatarInput"
                           name="avatarFile"
                           hidden
                           accept="image/*" />

                </form>

            </div>

            <div class="profile-info">

                <h3 class="patient-name">
                    @Model.FullName
                </h3>

                <p>@Model.Email</p>

                <p>@Model.Phone</p>

                <p>@Model.Address</p>

                <a asp-action="EditProfile"
                   class="btn btn-primary mt-3">
                    <i class="fa-solid fa-edit"></i> Chỉnh sửa hồ sơ
                </a>
            </div>
        </div>

        <div class="quick-stats">

            <h5>Thống kê nhanh</h5>

            <div class="stat-item">
                <span class="label">Tổng lịch hẹn</span>
                <span class="value">@ViewBag.TotalAppointments</span>
            </div>

            <div class="stat-item">
                <span class="label">Chờ xác nhận</span>
                <span class="value">@ViewBag.PendingAppointments</span>
            </div>

            <div class="stat-item">
                <span class="label">Hoàn thành</span>
                <span class="value">@ViewBag.CompletedAppointments</span>
            </div>

            <div class="stat-item">
                <span class="label">Đã hủy</span>
                <span class="value">@ViewBag.CancelledAppointments</span>
            </div>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="appointments-section">
            <div class="section-header">
                <h2>📅 Lịch hẹn</h2>

                <div class="appointment-filter">

                    <a asp-action="Profile"
                       asp-route-status="all"
                       class="filter @(ViewBag.Status == "all" ? "active" : "")">
                        Tất cả
                    </a>

                    <a asp-action="Profile"
                       asp-route-status="pending"
                       class="filter @(ViewBag.Status == "pending" ? "active" : "")">
                        Chờ
                    </a>

                    <a asp-action="Profile"
                       asp-route-status="completed"
                       class="filter @(ViewBag.Status == "completed" ? "active" : "")">
                        Hoàn thành
                    </a>

                    <a asp-action="Profile"
                       asp-route-status="cancelled"
                       class="filter @(ViewBag.Status == "cancelled" ? "active" : "")">
                        Đã hủy
                    </a>

                </div>
            </div>

            @{
                var appointments =
                ViewBag.Appointments as List<Health_Booking_MVC.Models.Appointment>;
            }

            @if (appointments != null && appointments.Any())
            {
                foreach (var item in appointments)
                {
                    <div class="appointment-card">

                        <h5>
                            @item.Doctor?.FullName
                        </h5>

                        <p>
                            <strong>Ngày khám:</strong>
                            @item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")
                        </p>

                        <p>
                            <strong>Trạng thái:</strong>

                            @if (item.Status == Health_Booking_MVC.Models.AppointmentStatus.Pending)
                            {
                                <span class="badge bg-warning">
                                    Chờ xác nhận
                                </span>
                            }
                            else if (item.Status == Health_Booking_MVC.Models.AppointmentStatus.Confirmed)
                            {
                                <span class="badge bg-primary">
                                    Đã xác nhận
                                </span>
                            }
                            else if (item.Status == Health_Booking_MVC.Models.AppointmentStatus.Completed)
                            {
                                <span class="badge bg-success">
                                    Hoàn thành
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Đã hủy
                                </span>
                            }
                        </p>
                    </div>
                }
            }
            else
            {
                <p>Chưa có lịch hẹn nào.</p>
            }
        </div>

        <div class="requests-section">
            <div class="section-header">
                <h2>📋 Lịch khám đã đặt qua form</h2>
            </div>

            @{
                var bookingRequests =
                    ViewBag.BookingRequests as List<Health_Booking_MVC.Models.Appointment>;
            }

            @if (bookingRequests != null && bookingRequests.Any())
            {
                foreach (var item in bookingRequests)
                {
                    <div class="booking-request-card">

                        <div class="booking-header">

                            <div>
                                <h4>@item.Hospital?.Name</h4>

                                <p class="booking-info">
                                    Ngày @item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")
                                    • @item.Specialization?.Name
                                </p>
                            </div>

                            <span class="status-badge">
                                Đang Chờ Duyệt
                            </span>

                        </div>

                        <p class="booking-note">
                            Yêu cầu của bạn đang được đội ngũ chăm sóc khách hàng xử lý.
                        </p>

                    </div>
                }
            }
            else
            {
                <p>Chưa có yêu cầu nào.</p>
            }
        </div>
    </div>
</div>

<script>

    document.getElementById("avatarInput")
        ?.addEventListener("change", function () {

            document.getElementById("avatarForm").submit();

        });

</script>